4class Solution {
5    public boolean isBipartite(int[][] graph) {
6        int n = graph.length; // no of vertices
7
8        int colors[] = new int[n]; // color array which also represennt the visited array
9
10        Arrays.fill(colors , -1); // minus one fill 
11
12        ArrayList<ArrayList<Integer>> adj= new ArrayList<>();
13
14        for(int i=0;i<n;i++){
15            ArrayList<Integer> curr = new ArrayList<>();
16            for(int j=0;j<graph[i].length;j++){
17                curr.add(graph[i][j]);
18            }
19            adj.add(curr);
20        }
21
22        // connected componenet concept : 
23        for(int i=0;i<n;i++){
24            if(colors[i] == -1){
25                if(dfs(i ,adj , 0 , colors) == false) return false;
26            }
27        }
28
29        return true;
30    }
31    public boolean dfs(int node ,ArrayList<ArrayList<Integer>> adj , int color , int[] visited){
32        visited[node] = color;
33
34        for(Integer x : adj.get(node)){
35            if(visited[x] == color) return false;
36
37            else if(visited[x] == -1){
38                if(dfs(x ,adj,1 - color,visited) == false) return false;
39            }
40        }
41
42        return true;
43    }
44}